  <DevelopmentNotes>
    <TechnicalDecisions>
      <Decision id="TD-001">
        <Topic>数据存储</Topic>
        <Choice>使用 JSON 文件存储博客数据</Choice>
        <Reason>简单直接，易于版本控制，便于内容管理和更新</Reason>
        <Alternative>Headless CMS（如 Notion、Contentful）</Alternative>
      </Decision>

      <Decision id="TD-002">
        <Topic>虚拟列表</Topic>
        <Choice>使用 vue-virtual-scroller 库</Choice>
        <Reason>性能优秀，API 简洁，社区支持好</Reason>
        <Alternative>vue-virtual-list</Alternative>
      </Decision>

      <Decision id="TD-003">
        <Topic>分页逻辑</Topic>
        <Choice>在 Store 中实现分页逻辑</Choice>
        <Reason>便于复用和管理，统一状态管理</Reason>
        <Alternative>在组件中实现</Alternative>
      </Decision>

      <Decision id="TD-004">
        <Topic>主题系统</Topic>
        <Choice>所有组件支持主题系统（colorScheme, uiStyle）</Choice>
        <Reason>与 UI-UX-Pro-Max 深度集成，提供个性化定制体验</Reason>
        <Alternative>固定主题</Alternative>
      </Decision>
    </TechnicalDecisions>

    <PerformanceOptimizationStrategies>
      <Strategy>
        <Name>代码分割</Name>
        <Description>路由级懒加载，减少首屏加载大小</Description>
        <Implementation>
          <Code language="typescript">
            component: () => import('@/views/Blog.vue')
          </Code>
        </Implementation>
      </Strategy>

      <Strategy>
        <Name>虚拟列表</Name>
        <Description>≥50 篇时启用虚拟滚动，只渲染可见区域</Description>
        <Condition>posts.length >= 50</Condition>
      </Strategy>

      <Strategy>
        <Name>图片优化</Name>
        <Description>使用 WebP 格式，懒加载</Description>
        <Implementation>
          <Code language="vue">
            &lt;img :src="post.coverImage" loading="lazy" decoding="async" /&gt;
          </Code>
        </Implementation>
      </Strategy>

      <Strategy>
        <Name>缓存优化</Name>
        <Description>使用浏览器缓存，减少重复加载</Description>
        <Implementation>
          <Code language="typescript">
            const cachedPosts = localStorage.getItem('blogPosts')
            if (cachedPosts) {
              posts.value = JSON.parse(cachedPosts)
            }
          </Code>
        </Implementation>
      </Strategy>

      <Strategy>
        <Name>渲染优化</Name>
        <Description>使用 v-memo、key 优化渲染性能</Description>
        <Implementation>
          <Code language="vue">
            &lt;BlogCard v-for="post in paginatedPosts" :key="post.id" :post="post" /&gt;
          </Code>
        </Implementation>
      </Strategy>
    </PerformanceOptimizationStrategies>

    <AccessibilityGuidelines>
      <Guideline>支持键盘导航（Tab 键）</Guideline>
      <Guideline>清晰的 Focus 状态</Guideline>
