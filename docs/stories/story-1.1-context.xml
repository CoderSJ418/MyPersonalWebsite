  <!-- ============================================
       用户故事
       ============================================ -->
  <UserStory>
    <Role>前端开发者</Role>
    <Action>看到一个按时间倒序排列的文章列表，包含标题、摘要、发布时间、分类和标签</Action>
    <Benefit>快速浏览最新的技术文章</Benefit>
  </UserStory>

  <!-- ============================================
       技术指导
       ============================================ -->
  <TechnicalGuidance>
    <TechnologyStack>
      <Framework>Vue 3.4.15</Framework>
      <Language>TypeScript 5.3.3</Language>
      <StateManagement>Pinia 2.1.7</StateManagement>
      <Routing>Vue Router 4.2.5</Routing>
      <Styling>Tailwind CSS 3.4.1</Styling>
      <Animation>GSAP 3.14.2</Animation>
      <Icons>Lucide Vue Next 0.312.0</Icons>
      <VirtualScroll>vue-virtual-scroller</VirtualScroll>
    </TechnologyStack>

    <ComponentArchitecture>
      <Component name="BlogList" path="src/components/blog/BlogList.vue">
        <Purpose>文章列表容器组件，负责布局和分页</Purpose>
        <Props>
          <Prop name="posts" type="BlogPost[]" required="true" />
          <Prop name="currentPage" type="number" required="true" />
          <Prop name="totalPages" type="number" required="true" />
          <Prop name="loading" type="boolean" default="false" />
          <Prop name="error" type="string | null" default="null" />
        </Props>
        <Events>
          <Event name="page-change" type="(page: number) => void" />
          <Event name="post-click" type="(postId: string) => void" />
        </Events>
        <CompositionAPI>
          <Hook>ref</Hook>
          <Hook>computed</Hook>
          <Hook>watch</Hook>
          <Hook>onMounted</Hook>
        </CompositionAPI>
        <ResponsiveDesign>
          <Breakpoint device="desktop" minWidth="1024" columns="3" />
          <Breakpoint device="tablet" minWidth="768" maxWidth="1023" columns="2" />
          <Breakpoint device="mobile" maxWidth="767" columns="1" />
        </ResponsiveDesign>
      </Component>

      <Component name="BlogCard" path="src/components/blog/BlogCard.vue">
        <Purpose>单个文章卡片组件，负责文章信息展示</Purpose>
        <Props>
          <Prop name="post" type="BlogPost" required="true" />
          <Prop name="lazy" type="boolean" default="true" />
          <Prop name="showTags" type="boolean" default="true" />
        </Props>
        <Events>
          <Event name="click" type="() => void" />
          <Event name="tag-click" type="(tag: string) => void" />
        </Events>
        <Features>
          <Feature>悬浮效果（阴影加深、轻微上移）</Feature>
          <Feature>点击跳转到文章详情页</Feature>
          <Feature>标签点击事件</Feature>
          <Feature>分类显示</Feature>
          <Feature>阅读时长显示</Feature>
        </Features>
        <ThemeSupport>
          <ColorScheme>professional-minimal</ColorScheme>
          <UIStyle>glass-morphism</UIStyle>
          <DarkMode>true</DarkMode>
        </ThemeSupport>
      </Component>

      <Component name="Pagination" path="src/components/common/Pagination.vue">
        <Purpose>分页组件，负责页码切换</Purpose>
        <Props>
          <Prop name="currentPage" type="number" required="true" />
          <Prop name="totalPages" type="number" required="true" />
          <Prop name="maxVisible" type="number" default="7" />
        </Props>
        <Events>
          <Event name="page-change" type="(page: number) => void" />
        </Events>
        <Features>
          <Feature>上一页/下一页按钮</Feature>
          <Feature>页码点击跳转</Feature>
          <Feature>禁用状态（第一页禁用"上一页"，最后一页禁用"下一页"）</Feature>
          <Feature>省略号显示（页码过多时）</Feature>
        </Features>
      </Component>

      <Component name="VirtualBlogList" path="src/components/blog/VirtualBlogList.vue">
        <Purpose>虚拟列表组件，用于长列表优化</Purpose>
        <Props>
          <Prop name="items" type="BlogPost[]" required="true" />
          <Prop name="itemSize" type="number" default="200" />
          <Prop name="buffer" type="number" default="5" />
        </Props>
        <Conditions>
          <Condition>posts.length >= 50 时启用</Condition>
        </Conditions>
        <Performance>
          <Metric>滚动帧率 >= 60fps</Metric>
          <Metric>只渲染可见区域</Metric>
          <Metric>内存占用 <= 50MB</Metric>
        </Performance>
      </Component>

      <Component name="SkeletonLoader" path="src/components/common/SkeletonLoader.vue">
        <Purpose>骨架屏加载组件</Purpose>
        <Props>
          <Prop name="type" type="'card' | 'list' | 'text'" default="card" />
          <Prop name="count" type="number" default="3" />
        </Props>
        <Usage>
          <Scenario>初始加载时显示骨架屏</Scenario>
          <Scenario>分页切换时显示加载状态</Scenario>
        </Usage>
      </Component>
    </ComponentArchitecture>

    <StateManagement>
      <Store name="useBlogStore" path="src/stores/useBlogStore.ts">
        <State>
          <Property name="posts" type="BlogPost[]" />
          <Property name="filteredPosts" type="ComputedRef&lt;BlogPost[]&gt;" />
          <Property name="selectedTag" type="string | null" />
          <Property name="searchQuery" type="string" />
          <Property name="loading" type="boolean" />
          <Property name="error" type="string | null" />
          <Property name="currentPage" type="number" />
          <Property name="totalPages" type="number" />
          <Property name="itemsPerPage" type="number" />
        </State>
        <Actions>
          <Action name="loadPosts" async="true" />
          <Action name="loadPost" async="true" params="id: string" />
          <Action name="filterByTag" params="tag: string | null" />
          <Action name="searchPosts" params="query: string" />
          <Action name="setPage" params="page: number" />
          <Action name="getPostById" params="id: string" returnType="BlogPost | undefined" />
        </Actions>
        <Getters>
          <Getter name="sortedPosts" description="按发布时间倒序排列" />
          <Getter name="paginatedPosts" description="当前页的文章列表" />
          <Getter name="allTags" description="所有标签列表" />
          <Getter name="recentPosts" description="最近5篇文章" />
        </Getters>
      </Store>
    </StateManagement>

    <DataModels>
      <Interface name="BlogPost">
        <Property name="id" type="string" />
        <Property name="title" type="string" />
        <Property name="summary" type="string" />
        <Property name="content" type="string" />
        <Property name="excerpt" type="string" />
        <Property name="author" type="string" />
        <Property name="publishedAt" type="string" format="YYYY-MM-DD" />
        <Property name="updatedAt" type="string" format="YYYY-MM-DD" />
        <Property name="tags" type="string[]" />
        <Property name="category" type="string" />
        <Property name="readTime" type="number" unit="minutes" />
        <Property name="coverImage" type="string" optional="true" />
        <Property name="featured" type="boolean" optional="true" />
        <Property name="codeVersion" type="CodeVersion" optional="true" />
      </Interface>

      <Interface name="CodeVersion">
        <Property name="vue" type="string" optional="true" />
        <Property name="typescript" type="string" optional="true" />
        <Property name="vite" type="string" optional="true" />
        <Property name="tailwindcss" type="string" optional="true" />
      </Interface>
    </DataModels>

    <Patterns>
      <Pattern name="Composition API">
        <Description>使用 Vue 3 Composition API 组织组件逻辑</Description>
        <Example>
          <Code language="typescript">
            import { ref, computed, onMounted } from 'vue'
            
            const posts = ref&lt;BlogPost[]&gt;([])
            const loading = ref(false)
            
            const sortedPosts = computed(() => {
              return [...posts.value].sort((a, b) => 
                new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
              )
            })
            
            onMounted(() => {
              loadPosts()
            })
          </Code>
        </Example>
      </Pattern>

      <Pattern name="Virtual Scrolling">
        <Description>长列表使用虚拟滚动优化性能</Description>
        <Condition>文章数量 >= 50 时启用</Condition>
        <Library>vue-virtual-scroller</Library>
        <Example>
          <Code language="vue">
            &lt;RecycleScroller
              :items="posts"
              :item-size="200"
              key-field="id"
              v-slot="{ item }"
            &gt;
              &lt;BlogCard :post="item" /&gt;
            &lt;/RecycleScroller&gt;
          </Code>
        </Example>
      </Pattern>

      <Pattern name="Responsive Grid">
        <Description>使用 Tailwind CSS Grid 实现响应式布局</Description>
        <Example>
          <Code language="vue">
            &lt;div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"&gt;
              &lt;BlogCard v-for="post in posts" :key="post.id" :post="post" /&gt;
            &lt;/div&gt;
          </Code>
        </Example>
      </Pattern>

      <Pattern name="Lazy Loading">
        <Description>图片和组件懒加载优化性能</Description>
        <Example>
          <Code language="vue">
            &lt;img :src="post.coverImage" loading="lazy" decoding="async" /&gt;
          </Code>
        </Example>
      </Pattern>

      <Pattern name="Theme System">
        <Description>支持主题系统（colorScheme, uiStyle, darkMode）</Description>
        <Example>
          <Code language="vue">
            &lt;article
              class="blog-card"
              :class="[
                `blog-card--${uiStyle}`,
                `blog-card--${colorScheme}`,
                { 'blog-card--dark': darkMode }
              ]"
            &gt;
              <!-- 内容 -->
            &lt;/article&gt;
          </Code>
        </Example>
      </Pattern>
    </Patterns>
  </TechnicalGuidance>

