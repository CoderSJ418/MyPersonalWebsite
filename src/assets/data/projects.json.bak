[{"id": "1", "title": "澳斯康生物官网重构项目", "description": "基于 Vue 3 + TypeScript + Vite 的现代化官网重构，首屏加载从 3.5 秒优化到 1.5 秒，Lighthouse 性能评分 95+。", "coverImage": "/images/projects/auskang.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "Vite", "version": "5.0.12"}, {"name": "Element Plus", "version": "2.5.0"}], "category": "企业官网", "featured": true, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2023-12-01", "updatedAt": "2024-03-31", "background": "原官网技术栈老旧，首屏加载超过 3.5 秒，SEO 效果差，影响品牌形象和获客。需要搭建一个现代化的企业官网，提升用户体验和搜索引擎排名。", "goals": ["提升网站加载速度，优化首屏性能", "改善 SEO 效果，提高搜索引擎排名", "提升用户体验，增加用户停留时间", "提升品牌形象，增强企业竞争力"], "features": ["响应式设计，支持多终端访问", "动态 Meta 管理，优化 SEO", "产品展示模块，支持图片轮播", "新闻资讯模块，支持分页和筛选", "联系我们模块，支持表单验证"], "techHighlights": {"architecture": "基于 Vue 3 Composition API + TypeScript + Vite 的现代化架构", "keyImplementations": ["路由级代码分割，按需加载页面", "图片 WebP 转换和懒加载，减少首屏资源大小", "CDN 加速，提升资源加载速度", "动态 Meta 管理，优化 SEO", "组件库封装，提高开发效率"], "performanceOptimizations": ["路由级代码分割，减少首屏加载体积", "图片 WebP 转换和懒加载，优化图片加载", "CDN 加速，提升资源加载速度", "资源预加载，优化关键渲染路径"], "solution": "在不使用 SSR 的情况下，通过路由级代码分割、图片优化、CDN 加速、动态 Meta 管理等技术手段，实现优秀的 SEO 效果和性能表现。"}, "results": {"performance": "首屏加载从 3.5 秒优化到 1.5 秒", "lighthouse": "Lighthouse 性能评分 95+（Performance 96, SEO 98）", "business": "搜索引擎收录量和自然流量都有明显增长", "feedback": "用户反馈良好，品牌形象得到提升"}, "screenshots": ["/images/projects/auskang-1.png", "/images/projects/auskang-2.png", "/images/projects/auskang-3.png"]}, {"id": "2", "title": "企业后台管理系统", "description": "基于 Vue 3 + Element Plus 的企业级后台管理系统，支持 20+ 个业务模块，权限系统被多个项目复用。", "coverImage": "/images/projects/admin-system.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "Pinia", "version": "2.1.7"}, {"name": "Element Plus", "version": "2.5.0"}, {"name": "ECharts", "version": "5.4.0"}], "category": "后台管理", "featured": true, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2023-10-01", "updatedAt": "2024-02-28", "background": "公司原有管理系统功能分散、权限控制混乱，需要开发一个统一的后台管理系统，整合所有业务模块，提供统一的权限管理和数据可视化功能。", "goals": ["整合所有业务模块，提供统一的管理入口", "设计灵活的权限系统，支持角色继承和权限组合", "提供数据可视化看板，支持实时数据更新", "优化大数据列表性能，确保万级数据流畅滚动", "提供表单配置化方案，提高开发效率"], "features": ["基于 RBAC 的权限管理系统", "动态路由和按钮级权限控制", "数据可视化看板，支持数据下钻", "大数据列表虚拟滚动", "表单配置化方案", "实时数据更新"], "techHighlights": {"architecture": "基于 Vue 3 + Pinia + Element Plus 的现代化后台管理系统架构", "keyImplementations": ["基于 RBAC 的权限系统，支持角色继承和权限组合", "动态路由和按钮级权限控制", "ECharts 数据可视化看板，支持数据下钻和实时更新", "大数据列表虚拟滚动，确保万级数据流畅滚动", "表单配置化方案，支持动态表单和表单验证"], "performanceOptimizations": ["虚拟滚动优化，确保万级数据流畅滚动", "按需加载图表数据，减少首屏加载体积", "缓存优化，减少重复请求"], "solution": "设计了一个基于角色的权限系统（RBAC），支持动态路由和按钮级权限控制，解决了权限缓存、权限更新同步等技术难点，后来被其他项目复用。"}, "results": {"performance": "系统首屏加载 1.2 秒左右", "modules": "支持 20+ 个业务模块", "reuse": "权限系统被多个项目复用", "satisfaction": "运营效率有明显提升，用户满意度高"}, "screenshots": ["/images/projects/admin-1.png", "/images/projects/admin-2.png", "/images/projects/admin-3.png"]}, {"id": "3", "title": "个人博客系统", "description": "基于 Vue 3 + TypeScript 的现代化个人博客系统，支持 Markdown 渲染、代码高亮、主题切换等功能。", "coverImage": "/images/projects/blog-system.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "Pinia", "version": "2.1.7"}, {"name": "Tailwind CSS", "version": "3.4.1"}, {"name": "markdown-it", "version": "14.0.0"}], "category": "个人项目", "featured": true, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2024-01-01", "updatedAt": "2024-01-22", "background": "需要一个现代化的个人博客系统，用于分享技术文章、记录开发经验、展示个人能力。要求支持 Markdown 渲染、代码高亮、主题切换等功能，提供良好的阅读体验。", "goals": ["支持 Markdown 渲染，方便撰写技术文章", "提供代码高亮功能，提升代码可读性", "支持主题切换，提供个性化阅读体验", "优化 SEO，提高搜索引擎排名", "提供良好的响应式设计，支持多终端访问"], "features": ["Markdown 渲染，支持 CommonMark 和 GFM", "代码高亮，支持多种语言", "主题切换，支持亮色和暗色主题", "目录导航，支持长文阅读", "相关文章推荐", "上一篇/下一篇导航"], "techHighlights": {"architecture": "基于 Vue 3 + Pinia + Tailwind CSS 的现代化博客系统架构", "keyImplementations": ["markdown-it 渲染 Markdown 内容", "highlight.js 代码高亮", "动态主题切换，基于 CSS 变量", "目录导航，基于 Intersection Observer API", "虚拟列表优化长列表渲染"], "performanceOptimizations": ["虚拟列表优化长列表渲染", "图片懒加载，优化首屏加载", "路由级代码分割，减少首屏加载体积"], "solution": "使用 markdown-it 渲染 Markdown 内容，集成 highlight.js 实现代码高亮，使用 CSS 变量实现动态主题切换，使用 Intersection Observer API 实现目录导航。"}, "results": {"performance": "首屏加载 1 秒左右", "features": "支持所有核心功能", "satisfaction": "阅读体验良好，用户反馈积极"}, "screenshots": ["/images/projects/blog-1.png", "/images/projects/blog-2.png", "/images/projects/blog-3.png"]}, {"id": "4", "title": "电商平台移动端", "description": "基于 Vue 3 + Vant 的电商平台移动端应用，支持商品浏览、购物车、订单管理等功能。", "coverImage": "/images/projects/ecommerce-mobile.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "Vant", "version": "4.8.0"}, {"name": "Pinia", "version": "2.1.7"}], "category": "移动应用", "featured": false, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2024-02-01", "updatedAt": "2024-02-28", "background": "需要一个电商平台移动端应用，支持商品浏览、购物车、订单管理等功能。要求界面美观、交互流畅、性能优秀。", "goals": ["提供流畅的用户体验", "支持商品浏览和搜索", "支持购物车和订单管理", "优化移动端性能", "提供良好的交互反馈"], "features": ["商品浏览和搜索", "购物车功能", "订单管理", "用户中心", "支付功能"], "techHighlights": {"architecture": "基于 Vue 3 + Vant + Pinia 的移动端应用架构", "keyImplementations": ["Vant UI 组件库，提供丰富的移动端组件", "Pinia 状态管理，管理购物车和订单", "图片懒加载，优化性能", "虚拟滚动，优化长列表渲染"], "performanceOptimizations": ["图片懒加载，优化首屏加载", "虚拟滚动，优化长列表渲染", "路由级代码分割，减少首屏加载体积"], "results": {"performance": "首屏加载 1.5 秒左右", "features": "支持所有核心功能", "satisfaction": "用户体验良好，性能优秀"}, "screenshots": ["/images/projects/ecommerce-1.png", "/images/projects/ecommerce-2.png", "/images/projects/ecommerce-3.png"]}, {"id": "5", "title": "数据可视化大屏", "description": "基于 Vue 3 + ECharts 的数据可视化大屏，支持实时数据更新、图表交互、响应式布局。", "coverImage": "/images/projects/data-visualization.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "ECharts", "version": "5.4.0"}, {"name": "Tailwind CSS", "version": "3.4.1"}], "category": "数据可视化", "featured": false, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2024-03-01", "updatedAt": "2024-03-15", "background": "需要一个数据可视化大屏，用于展示企业业务数据。要求支持实时数据更新、图表交互、响应式布局，提供良好的数据展示效果。", "goals": ["提供实时数据更新功能", "支持图表交互，提升数据探索能力", "支持响应式布局，适应不同屏幕", "优化性能，确保流畅渲染", "提供美观的视觉效果"], "features": ["实时数据更新", "图表交互（缩放、下钻、筛选）", "响应式布局", "多种图表类型", "数据导出功能"], "techHighlights": {"architecture": "基于 Vue 3 + ECharts + Tailwind CSS 的数据可视化大屏架构", "keyImplementations": ["ECharts 数据可视化，支持多种图表类型", "WebSocket 实时数据更新", "响应式布局，适应不同屏幕", "虚拟滚动，优化长列表渲染"], "performanceOptimizations": ["虚拟滚动，优化长列表渲染", "按需加载图表数据，减少首屏加载体积", "缓存优化，减少重复请求"], "results": {"performance": "首屏加载 1.2 秒左右", "features": "支持所有核心功能", "satisfaction": "数据展示效果良好，性能优秀"}, "screenshots": ["/images/projects/data-1.png", "/images/projects/data-2.png", "/images/projects/data-3.png"]}, {"id": "6", "title": "在线教育平台", "description": "基于 Vue 3 + Element Plus 的在线教育平台，支持课程管理、在线学习、考试系统等功能。", "coverImage": "/images/projects/education-platform.png", "techStack": [{"name": "Vue", "version": "3.4.15"}, {"name": "TypeScript", "version": "5.3.3"}, {"name": "Element Plus", "version": "2.5.0"}, {"name": "Pinia", "version": "2.1.7"}, {"name": "Vite", "version": "5.0.12"}], "category": "教育平台", "featured": false, "demoUrl": "https://example.com", "githubUrl": "https://github.com/example", "createdAt": "2024-01-15", "updatedAt": "2024-02-15", "background": "需要一个在线教育平台，支持课程管理、在线学习、考试系统等功能。要求界面美观、交互流畅、性能优秀。", "goals": ["提供流畅的用户体验", "支持课程管理和发布", "支持在线学习和进度跟踪", "支持考试系统和成绩管理", "优化性能，确保流畅渲染"], "features": ["课程管理和发布", "在线学习和进度跟踪", "考试系统和成绩管理", "用户中心", "讨论区"], "techHighlights": {"architecture": "基于 Vue 3 + Element Plus + Pinia 的在线教育平台架构", "keyImplementations": ["Element Plus UI 组件库，提供丰富的组件", "Pinia 状态管理，管理课程和学习进度", "虚拟滚动，优化长列表渲染", "图片懒加载，优化首屏加载"], "performanceOptimizations": ["图片懒加载，优化首屏加载", "虚拟滚动，优化长列表渲染", "路由级代码分割，减少首屏加载体积"], "results": {"performance": "首屏加载 1.3 秒左右", "features": "支持所有核心功能", "satisfaction": "用户体验良好，性能优秀"}, "screenshots": ["/images/projects/education-1.png", "/images/projects/education-2.png", "/images/projects/education-3.png"]}]